# Flask
SECRET_KEY=change-this-secret

# Supabase Postgres (Transaction pooler example)
# Replace all placeholders with your values from Supabase project settings.
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Allowed frontends (comma separated)
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# Cookies for cross-site auth in production (frontend and backend on different domains)
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=None
