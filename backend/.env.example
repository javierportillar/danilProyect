# App
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret

# Supabase Postgres (pooler + SSL)
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Frontend domains allowed to call backend (comma separated)
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# Session/cookies (required if frontend and backend are in different domains)
SESSION_COOKIE_NAME=urbanfood_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=None
SESSION_MAX_AGE_HOURS=12

# Reverse proxy/platform headers (Render/Railway/Fly usually true)
TRUST_PROXY=true

# DB pool tuning
DB_POOL_RECYCLE=1800

# Gunicorn
WEB_CONCURRENCY=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
LOG_LEVEL=info
